# One-click deployment variables
AIRPORT_CONTAINER_NAME=airport-control-plane
AIRPORT_IMAGE_TAG=airport-control-plane:latest
AIRPORT_BIND_IP=0.0.0.0
AIRPORT_HOST_PORT=8080
AIRPORT_DATA_DIR=./data-prod

# Control-plane login
CONTROL_PLANE_AUTH_USERNAME=admin
CONTROL_PLANE_AUTH_PASSWORD=CHANGE_ME
CONTROL_PLANE_SESSION_TTL_MS=43200000

# If you terminate TLS at a reverse proxy and forward X-Forwarded-Proto=https,
# this may stay false. If you access the app directly over HTTPS, set it true.
CONTROL_PLANE_SESSION_SECURE=false

# Set this after binding a domain or public IP.
# Example: https://airport.example.com
PLATFORM_PUBLIC_BASE_URL=

# Optional: use a dedicated public domain for client subscriptions / share links.
# Example: https://sub.airport.example.com
CLIENT_PUBLIC_BASE_URL=

# Optional: use your own platform SSH key instead of the managed key under /app/data/platform-ssh
# If you set PLATFORM_SSH_PRIVATE_KEY_PATH, the file must already exist inside the container.
# The default install.sh path only mounts /app/data, so extra secret mounts need custom wiring.
# PLATFORM_SSH_PRIVATE_KEY_PATH=/run/secrets/platform-ssh/id_ed25519
# PLATFORM_PUBLIC_KEY=ssh-ed25519 AAAA...

NODE_SSH_USER=root
DEMO_SHELL_BINARY=/bin/sh
OPERATION_EXECUTION_TIMEOUT_MS=300000
SSH_CONNECT_TIMEOUT_SECONDS=15
PROBE_TCP_TIMEOUT_MS=4000
PROBE_SSH_TIMEOUT_MS=12000
AUTO_PROBE_ENABLED=true
AUTO_PROBE_INTERVAL_MS=900000
AUTO_PROBE_BATCH_SIZE=4
AUTO_PROBE_MIN_GAP_MS=600000
AUTO_PROBE_JITTER_MS=10000
TZ=Asia/Shanghai
